# ── Entorno ──────────────────────────────────────────────────
NODE_ENV=test
PORT=8081

# ── Base de datos de TEST (distinta a la de desarrollo) ───────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pymeflowec_test
DB_USER=postgres
DB_PASSWORD=root
DB_SSL=false

# ── JWT (secrets distintos a producción) ─────────────────────
JWT_SECRET=test_jwt_secret_minimo_32_caracteres_aqui
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=test_refresh_secret_minimo_32_caracteres
JWT_REFRESH_EXPIRES_IN=7d

# ── Mailer (no se usa en tests, pero evita errores de config) ─
MAIL_HOST=smtp.ethereal.email
MAIL_PORT=587
MAIL_USER=test@ethereal.email
MAIL_PASS=test_password
MAIL_FROM=PymeFlowEc Test <no-reply@test.com>

# ── Rate limiting muy alto para no bloquear tests ────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=10000

# ── Frontend URL ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# npm test -- unit/jest-config.test.js
# npm run test:integration
